# 内核源码地址
KERNEL_SOURCE=https://github.com/MiCode/Xiaomi_Kernel_OpenSource
# 内核源码分支
KERNEL_SOURCE_BRANCH=taoyao-s-oss

# 内核打包名称（建议改成容易区分的）
KERNEL_ZIP_NAME=taoyao-SukiSU-LXC

# LXC-Docker（你要的功能）
ENABLE_LXC_DOCKER=true

# LLVM 参数（必须保留 y）
LLVM_CONFIG=y

# KVM（不需要就保持 false）
ENABLE_KVM=false

# ==================== 可选/不影响的部分 ====================
# KERNEL_CONFIG=   # 故意留空或注释掉（已在 workflow 中处理）
SWITCH_PYTHON=false
NEED_DTBO=false
KERNEL_IMAGE_NAME=Image.gz-dtb

# ==================== SukiSU 设置 ====================
# 必须关闭原生 KernelSU
ENABLE_KERNELSU=false
KERNELSU_TAG=main
