# 内核源码地址
KERNEL_SOURCE=https://github.com/MiCode/Xiaomi_Kernel_OpenSource
# 内核源码分支
KERNEL_SOURCE_BRANCH=taoyao-s-oss
# 内核编译配置（这个基本没问题）
#KERNEL_CONFIG=vendor/taoyao_QGKI.config
# 内核打包名字
KERNEL_ZIP_NAME=taoyao-SukiSU
# KVM（一般不需要）
ENABLE_KVM=false
# LXC-Docker（你要的）
ENABLE_LXC_DOCKER=true
# 内核镜像
KERNEL_IMAGE_NAME=Image.gz-dtb
# LLVM 参数（小米5.4内核通常需要）
LLVM_CONFIG=y
# Python 切换（先保持false，失败再改true）
SWITCH_PYTHON=false
# DTBO（一般不需要）
NEED_DTBO=false

# ==================== SukiSU 设置 ====================
# 关闭原生 KernelSU（必须）
ENABLE_KERNELSU=false
# 下面两行可以保留或删除，不影响
KERNELSU_TAG=main
